{
  "$schema": "../docs/cache-rules-schema.json",
  "rules": [
    { "pattern": "**/credit-cards/**", "read_cache_enabled": false },
    { "pattern": "**/logs/**", "get_ttl": "0s" },
    { "pattern": "prod-*/static/**", "get_ttl": "7d", "compression_enabled": true },
    { "pattern": "my-bucket/temp/**", "get_ttl": "0s" },
    { "pattern": "**", "get_ttl": "5m" }
  ]
}
